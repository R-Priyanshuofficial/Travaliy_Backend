generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  password     String
  isVerified   Boolean  @default(false)
  profileImage String?
  createdAt    DateTime @default(now())

  trips               Trip[]
  expenseMemberships  ExpenseMember[]
  paidExpenses        Expense[]
  expenseSplits       ExpenseSplit[]
  settlementsPaid     ExpenseSettlement[] @relation("payer")
  settlementsReceived ExpenseSettlement[] @relation("receiver")
}

model Trip {
  id            String   @id @default(cuid())
  userId        String
  source        String
  destination   String
  startDate     DateTime
  endDate       DateTime
  tripMood      String?
  budget        String?
  itineraryData Json
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  expenseGroup ExpenseGroup?

  @@index([userId])
}

model Otp {
  id        String   @id @default(uuid())
  email     String
  otp       String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

// ─── EXPENSE MANAGEMENT ─────────────────────────────────────────────────

model ExpenseGroup {
  id        String   @id @default(cuid())
  tripId    String   @unique
  title     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trip        Trip                @relation(fields: [tripId], references: [id], onDelete: Cascade)
  members     ExpenseMember[]
  expenses    Expense[]
  settlements ExpenseSettlement[]
}

model ExpenseMember {
  id       String   @id @default(cuid())
  groupId  String
  userId   String
  joinedAt DateTime @default(now())

  group ExpenseGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([groupId])
  @@index([userId])
}

model Expense {
  id           String   @id @default(cuid())
  groupId      String
  title        String
  description  String?
  amount       Float
  category     String
  paidByUserId String
  createdAt    DateTime @default(now())

  group  ExpenseGroup   @relation(fields: [groupId], references: [id], onDelete: Cascade)
  paidBy User           @relation(fields: [paidByUserId], references: [id], onDelete: Cascade)
  splits ExpenseSplit[]

  @@index([groupId])
  @@index([paidByUserId])
}

model ExpenseSplit {
  id         String  @id @default(cuid())
  expenseId  String
  userId     String
  amountOwed Float
  isSettled  Boolean @default(false)

  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expenseId])
  @@index([userId])
}

model ExpenseSettlement {
  id             String   @id @default(cuid())
  groupId        String
  payerUserId    String
  receiverUserId String
  amount         Float
  createdAt      DateTime @default(now())

  group    ExpenseGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  payer    User         @relation("payer", fields: [payerUserId], references: [id], onDelete: Cascade)
  receiver User         @relation("receiver", fields: [receiverUserId], references: [id], onDelete: Cascade)

  @@index([groupId])
}
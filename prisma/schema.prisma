generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String   @id @default(cuid())
  name       String
  email      String   @unique
  password   String
  isVerified Boolean  @default(false)
  createdAt  DateTime @default(now())

  otps       OTP[]
}

model OTP {
  id        String   @id @default(cuid())
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())

  userId    String
  user      User @relation(fields: [userId], references: [id])
}